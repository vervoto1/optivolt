{
  "name": "optivolt",
  "version": "0.7.8",
  "description": "Optivolt is a linear and mixed-integer optimizer for home energy systems.",
  "homepage": "https://github.com/bmesuere/optivolt#readme",
  "bugs": {
    "url": "https://github.com/bmesuere/optivolt/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bmesuere/optivolt.git"
  },
  "license": "MIT",
  "author": "Bart Mesuere",
  "type": "module",
  "main": "api/index.ts",
  "scripts": {
    "api": "node ./api/index.ts",
    "dev": "dotenv -e .env.local -- nodemon --exec node --ignore 'data/' ./api/index.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "npx eslint ."
  },
  "engines": {
    "node": "^22.13.0 || >=24"
  },
  "dependencies": {
    "express": "^5.2.1",
    "highs": "^1.8.0",
    "mqtt": "^5.15.1"
  },
  "devDependencies": {
    "@eslint/css": "^1.1.0",
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^8.0.1",
    "@types/express": "^5.0.6",
    "@vitest/coverage-v8": "^4.1.4",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
