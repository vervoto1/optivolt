{
  "sensors": [
    { "id": "sensor.victron_mqtt_c0619ab6bd28_battery_512_battery_charged_energy", "name": "Battery Charge", "unit": "kWh" },
    { "id": "sensor.victron_mqtt_c0619ab6bd28_battery_512_battery_discharged_energy", "name": "Battery Discharge", "unit": "kWh" },
    { "id": "sensor.electricity_meter_energy_consumption_tarif_1", "name": "Grid Import", "unit": "kWh" },
    { "id": "sensor.electricity_meter_energy_consumption_tarif_2", "name": "Grid Import", "unit": "kWh" },
    { "id": "sensor.electricity_meter_energy_production_tarif_1", "name": "Grid Export", "unit": "kWh" },
    { "id": "sensor.electricity_meter_energy_production_tarif_2", "name": "Grid Export", "unit": "kWh" },
    { "id": "sensor.victron_mqtt_c0619ab6bd28_system_0_system_dc_pv_energy", "name": "Victron Solar", "unit": "kWh" },
    { "id": "sensor.envoy_122329007191_lifetime_energy_production", "name": "Enphase Solar", "unit": "MWh" },
    { "id": "sensor.tesla_wall_connector_energy", "name": "EV Charging", "unit": "kWh" }
  ],
  "derived": [
    {
      "name": "Solar Generation",
      "formula": ["+Victron Solar", "+Enphase Solar"]
    },
    {
      "name": "Total Load",
      "formula": ["+Solar Generation", "+Grid Import", "+Battery Discharge", "-Grid Export", "-Battery Charge"]
    },
    {
      "name": "Load without EV",
      "formula": ["+Total Load", "-EV Charging"]
    }
  ],
  "activeType": "historical",
  "historicalPredictor": {
    "sensor": "Total Load",
    "lookbackWeeks": 4,
    "dayFilter": "weekday-weekend",
    "aggregation": "mean"
  },
  "fixedPredictor": {
    "load_W": 200
  },
  "pvConfig": {
    "latitude": 51.05,
    "longitude": 3.71,
    "historyDays": 14,
    "pvSensor": "Solar Generation"
  }
}
